# ─── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://interviewos:interviewos@localhost:5432/interviewos?schema=public"
REDIS_URL="redis://localhost:6379"
WORKER_CONCURRENCY="2"

# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Pick one: gemini | groq | anthropic | openai
# Can also be changed at runtime via the Settings page (http://localhost:3000/settings)
LLM_PROVIDER="groq"

# Free providers (recommended for getting started)
# Groq  →  https://console.groq.com/keys       (Llama 3.3 70B, fast free tier)
GROQ_API_KEY="gsk_..."
# Google AI Studio  →  https://aistudio.google.com/app/apikey  (Gemini 2.5 Flash, free tier)
GEMINI_API_KEY="AIza..."

# Paid providers
# Anthropic  →  https://console.anthropic.com/settings/keys  (Claude Haiku 4.5)
ANTHROPIC_API_KEY="sk-ant-..."
# OpenAI  →  https://platform.openai.com/api-keys  (GPT-4o Mini)
OPENAI_API_KEY="sk-..."

# ─── Search Providers (optional — enriches company & salary research) ──────────
TAVILY_API_KEY="tvly-..."
EXA_API_KEY="..."
SERPAPI_KEY="..."

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="replace-me-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-me-with-a-long-random-secret"
